# =====================================================
# 0xLeaked - Variables de entorno
# Copia este archivo a .env y completa los valores.
# Nunca subir .env real al repositorio.
# =====================================================

# --- Blockchain (Monad + Alchemy) ---
ALCHEMY_API_KEY=
MONAD_RPC_URL=https://monad-testnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
MONAD_CHAIN_ID=10143

# Signing key del webhook de Alchemy (whsec_*). Opcional en local.
ALCHEMY_WEBHOOK_SIGNING_KEY=

# Wallet usada SOLO para deploy de contratos (nunca tu wallet personal).
# Debe tener MON en Monad Testnet para pagar gas del deploy.
DEPLOYER_PRIVATE_KEY=

# Wallet del SERVIDOR para firmar evidencias EIP-712 y enviar transacciones
# autenticadas como "verifier oficial". DEBE estar registrada como verifier
# en cada contrato (se hace automáticamente al deployar).
# Puede ser la misma del deployer en dev, pero en prod debería ser una wallet
# dedicada y restringida.
INDEXER_PRIVATE_KEY=

# Direcciones de contratos (se llenan tras el deploy a Monad testnet).
BREACH_REGISTRY_ADDRESS=
ALERT_ORACLE_ADDRESS=
REMEDIATION_VAULT_ADDRESS=

# Explorer de Monad (usado por el indexer para construir links).
MONAD_EXPLORER_URL=https://testnet.monadexplorer.com

# --- APIs externas ---
HIBP_API_KEY=
# IPFS via web3.storage. Opcional al inicio (necesario para reportes inmutables).
WEB3_STORAGE_TOKEN=

# --- Backend ---
API_GATEWAY_PORT=4000
BREACH_SERVICE_PORT=4101
ANALYZER_SERVICE_PORT=4102
ALERT_SERVICE_PORT=4103
BREACH_SERVICE_URL=http://localhost:4101
ANALYZER_SERVICE_URL=http://localhost:4102
ALERT_SERVICE_URL=http://localhost:4103
DATABASE_URL=postgresql://postgres:postgres@localhost:15432/0xleaked
REDIS_URL=redis://localhost:6379

# --- Frontend (variables públicas) ---
NEXT_PUBLIC_REOWN_PROJECT_ID=bc9aaff5d821ad595434ae61a052424b
NEXT_PUBLIC_APP_NAME=0xLeaked
NEXT_PUBLIC_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_GATEWAY_URL=http://localhost:4000
NEXT_PUBLIC_CHAIN_ID=10143
NEXT_PUBLIC_CHAIN_HEX_ID=0x279f
NEXT_PUBLIC_MONAD_CHAIN_NAME=Monad Testnet
NEXT_PUBLIC_MONAD_RPC_URL=https://monad-testnet.g.alchemy.com/v2/YOUR_ALCHEMY_KEY
NEXT_PUBLIC_MONAD_EXPLORER_URL=https://testnet.monadexplorer.com
NEXT_PUBLIC_ENABLED_MODULES=breach-scanner,contract-auditor,remediation-hub

# Direcciones públicas de los contratos (se llenan tras deploy a Monad)
NEXT_PUBLIC_BREACH_REGISTRY_ADDRESS=
NEXT_PUBLIC_ALERT_ORACLE_ADDRESS=
NEXT_PUBLIC_REMEDIATION_VAULT_ADDRESS=