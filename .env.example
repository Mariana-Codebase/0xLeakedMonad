# ──────────────────────────────────────────────────────────────
# 0xLeaked — variables de entorno (copia a .env y completa)
# ──────────────────────────────────────────────────────────────

# ── Red Monad ──
MONAD_RPC_URL=https://testnet-rpc.monad.xyz
MONAD_CHAIN_ID=10143
MONAD_EXPLORER_URL=https://testnet.monadexplorer.com
ALCHEMY_API_KEY=

# ── Claves (¡nunca commitear valores reales!) ──
# Wallet del verifier autorizado en BreachRegistry/AlertOracle (firma EIP-712 y paga gas)
INDEXER_PRIVATE_KEY=
# Wallet usada solo para desplegar contratos
DEPLOYER_PRIVATE_KEY=

# ── Contratos desplegados (Monad Testnet) ──
BREACH_REGISTRY_ADDRESS=0xC51DD0aD6593559F3E696b2281E9F6fa5D2af09E
ALERT_ORACLE_ADDRESS=0x4B9214a1349825373854fb9cBdFDdb585FB45587
REMEDIATION_VAULT_ADDRESS=0x68B31918a3827818097936b503bFf3378a932838

# ── APIs externas (opcionales: sin ellas hay modo degradado) ──
HIBP_API_KEY=
PINATA_JWT=
# Agente IA del Contract Auditor (Claude). Sin clave → solo heurísticas.
ANTHROPIC_API_KEY=
# Firma HMAC de webhooks Alchemy (sin ella el endpoint acepta cualquier payload)
ALCHEMY_WEBHOOK_SIGNING_KEY=

# ── Backend: puertos y URLs internas ──
API_GATEWAY_PORT=4000
BREACH_SERVICE_PORT=4101
ANALYZER_SERVICE_PORT=4102
ALERT_SERVICE_PORT=4103
BREACH_SERVICE_URL=http://localhost:4101
ANALYZER_SERVICE_URL=http://localhost:4102
ALERT_SERVICE_URL=http://localhost:4103
# Orígenes permitidos para CORS en producción (separados por comas). Vacío = todos.
CORS_ORIGIN=

# ── Frontend (NEXT_PUBLIC_*) ──
NEXT_PUBLIC_ENV=development
NEXT_PUBLIC_APP_NAME=0xLeaked
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_API_GATEWAY_URL=http://localhost:4000
NEXT_PUBLIC_ENABLED_MODULES=breach-scanner,contract-auditor,remediation-hub,alerts
NEXT_PUBLIC_REOWN_PROJECT_ID=
NEXT_PUBLIC_CHAIN_ID=10143
NEXT_PUBLIC_CHAIN_HEX_ID=0x279f
NEXT_PUBLIC_MONAD_RPC_URL=https://testnet-rpc.monad.xyz
NEXT_PUBLIC_MONAD_CHAIN_NAME=Monad Testnet
NEXT_PUBLIC_MONAD_EXPLORER_URL=https://testnet.monadexplorer.com
NEXT_PUBLIC_BREACH_REGISTRY_ADDRESS=0xC51DD0aD6593559F3E696b2281E9F6fa5D2af09E
NEXT_PUBLIC_ALERT_ORACLE_ADDRESS=0x4B9214a1349825373854fb9cBdFDdb585FB45587
NEXT_PUBLIC_REMEDIATION_VAULT_ADDRESS=0x68B31918a3827818097936b503bFf3378a932838
NEXT_PUBLIC_IPFS_GATEWAY_URL=https://gateway.pinata.cloud/ipfs
