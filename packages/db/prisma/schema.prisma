generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --------------------------------------------------------------------------
// Breach Scanner (Modulo 1)
// --------------------------------------------------------------------------

enum TargetType {
  email
  phone
  wallet
}

enum BreachSource {
  hibp
  simulated
  manual
  other
}

model Breach {
  id           Int          @id @default(autoincrement())
  targetHash   String       // 0x... keccak256
  targetType   TargetType
  source       BreachSource

  // Beneficiario on-chain (a quién pertenece la evidencia). Puede ser
  // address(0) si fue auto-registrado por el server sin user identificado.
  beneficiary  String?

  // Tx de registro on-chain (cuando ya fue minada).
  txHash       String?      @unique
  blockNumber  BigInt?
  reporter     String?      // msg.sender on-chain (server o user)

  // Datos enriquecidos de HIBP/fuente
  breachCount  Int          @default(0)
  rawBreaches  Json?        // lista cruda devuelta por HIBP
  confidence   Float?

  registeredAt DateTime?    // momento en que se confirmó on-chain
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  claims       BreachClaim[]

  @@unique([targetHash, source])
  @@index([targetHash])
  @@index([beneficiary])
}

// Cuando un usuario re-firma la evidencia con su propia wallet
// para reclamar ownership. Se crea un Breach nuevo con beneficiary=user
// y se vincula al Breach original via parentBreachId.
model BreachClaim {
  id              Int      @id @default(autoincrement())
  parentBreachId  Int
  parent          Breach   @relation(fields: [parentBreachId], references: [id], onDelete: Cascade)
  claimerAddress  String
  txHash          String   @unique
  blockNumber     BigInt
  claimedAt       DateTime @default(now())

  @@index([claimerAddress])
}

// --------------------------------------------------------------------------
// Contract Auditor (Modulo 2)
// --------------------------------------------------------------------------

enum RiskLabel {
  low
  medium
  high
}

model RiskScore {
  id              Int       @id @default(autoincrement())
  contractAddress String    @unique
  score           Int       // 0-100
  label           RiskLabel
  flags           Json      // lista de razones del score

  // Datos crudos de la auditoría
  bytecodeSize    Int?
  hasSelfdestruct Boolean   @default(false)
  hasDelegatecall Boolean   @default(false)
  verified        Boolean?
  alchemyMetadata Json?

  txHash          String?   @unique
  blockNumber     BigInt?
  registeredAt    DateTime?

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([score])
}

// --------------------------------------------------------------------------
// Alerts (sistema global de notificaciones)
// --------------------------------------------------------------------------

enum AlertSeverity {
  low
  medium
  high
}

model Alert {
  id        String        @id @default(cuid())
  source    String
  severity  AlertSeverity
  title     String
  summary   String
  payload   Json?
  createdAt DateTime      @default(now())

  @@index([createdAt])
  @@index([severity])
}

// --------------------------------------------------------------------------
// Indexer — archivo raw de eventos on-chain
// --------------------------------------------------------------------------

model OnChainEvent {
  id          BigInt   @id @default(autoincrement())
  chainId     Int
  contract    String
  eventName   String
  txHash      String
  blockNumber BigInt
  logIndex    Int
  args        Json     // argumentos del evento decodificados
  indexedAt   DateTime @default(now())

  @@unique([txHash, logIndex])
  @@index([contract, eventName])
  @@index([blockNumber])
}

// Tracking del último bloque indexado por contrato (para backfill resumible).
model IndexerCursor {
  contract       String  @id
  lastBlock      BigInt
  updatedAt      DateTime @updatedAt
}

// --------------------------------------------------------------------------
// EIP-712 nonces (anti-replay server-side)
// --------------------------------------------------------------------------

model Nonce {
  // Compuesta: "<verifierAddress>:<domain>" donde domain es 'breach' o 'audit'
  key        String   @id
  value      BigInt
  updatedAt  DateTime @updatedAt
}
